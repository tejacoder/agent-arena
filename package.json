{
  "name": "agent-arena",
  "version": "0.1.0",
  "description": "Agent Arena - Agent Competition Platform",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --experimental-specifier-resolution=node --loader ts-node/esm src/index.ts",
    "build": "tsc",
